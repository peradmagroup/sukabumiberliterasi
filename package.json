{
  "name": "literasi-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w packages/backend\" \"npm run dev -w packages/literasi-app\"",
    "dev:frontend": "npm run dev -w packages/literasi-app",
    "dev:backend": "npm run dev -w packages/backend"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
